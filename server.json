{
  "$schema": "https://schemas.nimblebrain.ai/v1/nimblebrain-server.schema.json",
  "name": "ai.nimblebrain/synapse-hello",
  "description": "Hello World MCP App for NimbleBrain Platform",
  "version": "0.1.0",
  "title": "Hello World Synapse App",
  "repository": {
    "url": "https://github.com/NimbleBrainInc/synapse-hello",
    "source": "https://github.com/NimbleBrainInc/synapse-hello"
  },
  "_meta": {
    "ai.nimblebrain/v1": {
      "runtime": "python:3.13",
      "capabilities": {
        "tools": true,
        "resources": true,
        "prompts": false
      },
      "display": {
        "category": "reference",
        "tags": [
          "synapse",
          "hello-world",
          "reference",
          "ui"
        ]
      },
      "deployment": {
        "protocol": "http",
        "port": 8000,
        "mcpPath": "/mcp"
      },
      "container": {
        "healthCheck": {
          "path": "/health",
          "port": 8000
        }
      },
      "resources": {
        "limits": {
          "memory": "256Mi",
          "cpu": "500m"
        },
        "requests": {
          "memory": "128Mi",
          "cpu": "100m"
        }
      },
      "scaling": {
        "minReplicas": 1,
        "maxReplicas": 2
      }
    }
  }
}
